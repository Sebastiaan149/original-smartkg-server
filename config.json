{
  "title": "Original SmartKG Linked Data Fragments server",

  "metadatapath": "../data/partitioning/metadata.json",
  "moleculesdatapath": "../data/partitioning/hdt",
  "datasourcetypes": {
    "HdtDatasource"       : "org.linkeddatafragments.datasource.hdt.HdtDataSourceType",
    "JenaTDBDatasource"   : "org.linkeddatafragments.datasource.tdb.JenaTDBDataSourceType"
  },

  "datasources": {
    "smartkg": {
      "title": "smartkg",
      "type": "HdtDatasource",
      "description": "SmartKG DataSet with an HDT back-end",
      "settings": { "file": "../data/dataset.hdt" },
      "serverType": "original-smartkg"
    }

  },

  "prefixes": {
    "rdf":         "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs":        "http://www.w3.org/2000/01/rdf-schema#",
    "xsd":         "http://www.w3.org/2001/XMLSchema#",
    "dc":          "http://purl.org/dc/terms/",
    "foaf":        "http://xmlns.com/foaf/0.1/",
    "dbpedia":     "http://dbpedia.org/resource/",
    "dbpedia-owl": "http://dbpedia.org/ontology/",
    "dbpprop":     "http://dbpedia.org/property/",
    "hydra":       "http://www.w3.org/ns/hydra/core#",
    "void":        "http://rdfs.org/ns/void#"
  }
}
